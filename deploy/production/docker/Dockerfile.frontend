# ============================================================
# CodeMind 前端 — 生产运行时镜像
# ============================================================
# 基于预构建的 dist 静态文件，无需在容器内执行 npm build
# Nginx 配置通过 docker-compose 的 volume 挂载注入
# ============================================================

FROM nginx:1.27-alpine

COPY dist/ /usr/share/nginx/html/

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
