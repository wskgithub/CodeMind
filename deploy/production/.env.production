# ============================================================
# CodeMind 生产环境配置
# ============================================================
# 将此文件复制为 .env 并修改以下配置项
# 标记 [必填] 的项目必须修改，[可选] 的可保持默认值
# ============================================================

# Docker Compose 项目名
COMPOSE_PROJECT_NAME=codemind

# 应用版本（由部署脚本自动设置，勿手动修改）
APP_VERSION=0.2.0

# ── 端口配置（使用非常用端口，避免与其他服务冲突）────────

# [可选] 前端访问端口（通过浏览器访问 http://服务器IP:18080）
FRONTEND_PORT=18080

# [可选] 数据库外部端口（用于数据库管理工具远程连接，如不需要可注释掉 docker-compose 中的端口映射）
DB_EXTERNAL_PORT=15432

# [可选] Redis 外部端口（一般不需要外部访问，如不需要可注释掉 docker-compose 中的端口映射）
REDIS_EXTERNAL_PORT=16379

# ── 数据库配置 ──────────────────────────────────────────

# [可选] 数据库名称
DB_NAME=codemind

# [可选] 数据库用户名
DB_USER=codemind

# [必填] 数据库密码（部署脚本会自动生成强密码）
DB_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# ── Redis 配置 ──────────────────────────────────────────

# [必填] Redis 密码（部署脚本会自动生成强密码）
REDIS_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# ── JWT 配置 ────────────────────────────────────────────

# [必填] JWT 签名密钥（至少 32 个字符，部署脚本会自动生成）
JWT_SECRET=CHANGE_ME_TO_RANDOM_STRING_AT_LEAST_32_CHARS

# ── LLM 服务配置 ────────────────────────────────────────

# [必填] LLM 服务地址（例: http://192.168.1.100:11434）
LLM_BASE_URL=http://your-llm-server:8080

# [可选] LLM API Key（如果 LLM 服务需要认证）
LLM_API_KEY=
